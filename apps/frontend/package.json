{
  "name": "@iotpilot/frontend",
  "version": "1.0.0",
  "description": "IoT Pilot — Next.js frontend",
  "scripts": {
    "dev": "NODE_ENV=development next dev",
    "build": "npm run type-check && NODE_ENV=production next build",
    "build:limited-errors": "tsc --noEmit --maxErrorCount 10 && NODE_ENV=production next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "type-check:limited": "tsc --noEmit --maxErrorCount 10",
    "db:generate": "prisma generate --schema=../backend/prisma/schema.prisma",
    "test": "vitest run",
    "test:unit": "vitest run src/__tests__/unit/",
    "test:integration": "vitest run src/__tests__/integration/",
    "test:e2e": "vitest run src/__tests__/e2e/",
    "test:performance": "vitest run src/__tests__/performance/",
    "test:frontend": "vitest run src/__tests__/frontend/",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:coverage:unit": "vitest --coverage src/__tests__/unit/",
    "test:coverage:integration": "vitest --coverage src/__tests__/integration/",
    "ddd:generate": "node scripts/generate-ddd-feature.js",
    "ddd": "node src/cli/index.ts",
    "pentest:tenants": "node scripts/tenant-security-pentest.js",
    "route:list": "node scripts/list-routes.js"
  },
  "keywords": [
    "iot",
    "device-management",
    "monitoring",
    "raspberry-pi",
    "next.js"
  ],
  "author": "IotPilot",
  "license": "MIT",
