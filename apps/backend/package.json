{
  "name": "@iotpilot/backend",
  "version": "0.1.0",
  "private": true,
  "description": "IoT Pilot — Express API backend",
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "db:generate": "prisma generate --schema=./prisma/schema.prisma",
    "db:migrate": "prisma migrate deploy --schema=./prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema=./prisma/schema.prisma",
    "db:migrate:dev": "prisma migrate dev --schema=./prisma/schema.prisma",
    "db:migrate:resolve": "prisma migrate resolve --applied --schema=./prisma/schema.prisma",
    "db:push": "prisma db push --schema=./prisma/schema.prisma --accept-data-loss"
  },
  "dependencies": {
    "@iotpilot/core": "workspace:*",
    "@prisma/client": "^6.19.0",
    "cookie-parser": "^1.4.7"
  },
  "devDependencies": {
    "prisma": "^6.19.0",
    "typescript": "5.8.3"
  }
}
