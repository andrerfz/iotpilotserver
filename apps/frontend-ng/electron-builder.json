{
  "appId": "com.iotpilot.desktop",
  "productName": "IoT Pilot",
  "directories": {
    "output": "dist-electron"
  },
  "files": [
    "electron/**/*",
    "www/**/*"
  ],
  "extraMetadata": {
    "main": "electron/main.js"
  },
  "mac": {
    "category": "public.app-category.utilities",
    "target": ["dmg", "dir"]
  },
  "win": {
    "target": ["nsis"]
  },
  "linux": {
    "target": ["AppImage"]
  }
}
