{
  "name": "frontend-ng",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "ng": "ng",
    "dev": "ng serve",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "type-check": "tsc --noEmit -p tsconfig.app.json",
    "format": "prettier --write \"src/**/*.{ts,html,scss,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss,css,json}\""
  },
  "dependencies": {
    "@angular/animations": "20.3.24",
    "@angular/common": "20.3.24",
    "@angular/compiler": "20.3.24",
    "@angular/core": "20.3.24",
    "@angular/forms": "20.3.24",
    "@angular/platform-browser": "20.3.24",
    "@angular/platform-browser-dynamic": "20.3.24",
    "@angular/router": "20.3.24",
    "@capacitor/core": "8.4.0",
    "@ionic/angular": "8.8.9",
    "ionicons": "7.4.0",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zone.js": "0.15.1"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "2.6.0",
    "@analogjs/vitest-angular": "2.6.0",
    "@angular-devkit/build-angular": "20.3.27",
    "@angular-eslint/builder": "20.7.0",
    "@angular-eslint/eslint-plugin": "20.7.0",
    "@angular-eslint/eslint-plugin-template": "20.7.0",
    "@angular-eslint/schematics": "20.7.0",
    "@angular-eslint/template-parser": "20.7.0",
    "@angular/cli": "20.3.27",
    "@angular/compiler-cli": "20.3.24",
    "@angular/language-service": "20.3.24",
    "@ionic/angular-toolkit": "12.3.0",
    "@testing-library/angular": "18.1.1",
    "@testing-library/dom": "10.4.1",
    "@types/node": "22.19.20",
    "@typescript-eslint/eslint-plugin": "8.18.0",
    "@typescript-eslint/parser": "8.18.0",
    "autoprefixer": "10.5.0",
    "eslint": "9.16.0",
    "eslint-plugin-import": "2.29.1",
    "eslint-plugin-jsdoc": "48.2.1",
    "eslint-plugin-prefer-arrow": "1.2.2",
    "jsdom": "26.1.0",
    "postcss": "8.5.15",
    "prettier": "3.4.2",
    "tailwindcss": "3.4.19",
    "typescript": "5.8.3",
    "vite": "8.0.16",
    "vitest": "4.1.8"
  }
}
