#!/usr/bin/env sh

echo "🔍 Running pre-commit checks in Docker..."
echo ""

# Check if Docker is running
if ! docker info > /dev/null 2>&1; then
    echo "❌ Docker is not running!"
    echo "💡 Please start Docker and ensure services are running:"
    echo "   make dev-start   (recommended: hot reload)"
    echo "   make local-start (alternative)"
    exit 1
fi

# Check if app container is running
if ! docker ps --format '{{.Names}}' | grep -q '^iotpilot-server-app$'; then
    echo "❌ Container 'iotpilot-server-app' is not running!"
    echo "💡 Start the development environment first:"
    echo "   make dev-start   (recommended: hot reload)"
    echo "   make local-start (alternative)"
    exit 1
fi

echo "✅ Docker environment ready"
echo ""

# Run linting
echo "📝 Linting code..."
if ! make lint; then
    echo ""
    echo "❌ Linting failed! Please fix errors before committing."
    exit 1
fi

echo ""
echo "🔎 Type checking..."
if ! docker exec -w /app/apps/frontend iotpilot-server-app npm run type-check; then
    echo ""
    echo "❌ TypeScript errors found! Please fix before committing."
    exit 1
fi

echo ""

# Warn when backend routes change but openapi.yml is not updated
CHANGED_ROUTES=$(git diff --cached --name-only | grep "apps/backend/src/routes/")
CHANGED_SPEC=$(git diff --cached --name-only | grep "docs/openapi.yml")

if [ -n "$CHANGED_ROUTES" ] && [ -z "$CHANGED_SPEC" ]; then
    echo "⚠️  Backend route files were modified but docs/openapi.yml was not updated."
    echo "   Changed route files:"
    echo "$CHANGED_ROUTES" | sed 's/^/     /'
    echo ""
    echo "   Run: make openapi-check   (see what's missing)"
    echo "   Then update docs/openapi.yml before pushing."
    echo ""
fi

# ── frontend-ng checks (only when apps/frontend-ng/** files are staged) ──────
NG_STAGED=$(git diff --cached --name-only | grep '^apps/frontend-ng/' | head -1 || true)
if [ -n "$NG_STAGED" ]; then
  echo "🅰️  Angular files staged — running frontend-ng checks..."
  echo ""

  if ! docker ps --format '{{.Names}}' | grep -q '^iotpilot-server-ng$'; then
    echo "❌ Container 'iotpilot-server-ng' is not running!"
    echo "💡 Start the Angular dev container: make ng-dev"
    exit 1
  fi

  echo "📝 Linting frontend-ng..."
  if ! make ng-lint; then
    echo ""
    echo "❌ ng-lint failed! Fix errors before committing."
    exit 1
  fi

  echo ""
  echo "🔎 Type-checking frontend-ng..."
  if ! make ng-type-check; then
    echo ""
    echo "❌ ng type-check failed! Fix TypeScript errors before committing."
    exit 1
  fi

  echo ""
fi

echo "✅ Pre-commit checks passed!"
echo "💡 Unit tests will run on push"