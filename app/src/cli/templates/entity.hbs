import { Entity } from '@/lib/shared/domain/base/entity.base';
import { {{pascalName}}Id } from '../value-objects/{{kebabName}}-id.vo';
{{#if data.generateEvents}}
import { DomainEvent } from '@/lib/shared/domain/events/domain-event.base';
{{/if}}

/**
 * {{name}} entity
 * {{data.description}}
 *
 * @author {{data.author}}
 * @license {{data.license}}
 */
export class {{pascalName}} extends Entity {
  private constructor(
    id: {{pascalName}}Id,
    private _name: string,
    private _description?: string,
    private _createdAt: Date = new Date(),
    private _updatedAt: Date = new Date()
  ) {
    super(id);
  }

  /**
   * Create a new {{name}}
   */
  static create(
    id: {{pascalName}}Id,
    name: string,
    description?: string
  ): {{pascalName}} {
    const {{camelName}} = new {{pascalName}}(
      id,
      name,
      description
    );

    {{#if data.generateEvents}}
    // Publish domain event
    {{camelName}}.addDomainEvent(new {{pascalName}}CreatedEvent(id, name));
    {{/if}}

    return {{camelName}};
  }

  /**
   * Update {{name}} name
   */
  updateName(name: string): void {
    if (!name || name.trim().length === 0) {
      throw new Error('Name cannot be empty');
    }

    this._name = name.trim();
    this._updatedAt = new Date();

    {{#if data.generateEvents}}
    this.addDomainEvent(new {{pascalName}}NameUpdatedEvent(this.id, name));
    {{/if}}
  }

  /**
   * Update {{name}} description
   */
  updateDescription(description?: string): void {
    this._description = description?.trim();
    this._updatedAt = new Date();
  }

  // Getters
  get id(): {{pascalName}}Id {
    return this._id as {{pascalName}}Id;
  }

  get name(): string {
    return this._name;
  }

  get description(): string | undefined {
    return this._description;
  }

  get createdAt(): Date {
    return this._createdAt;
  }

  get updatedAt(): Date {
    return this._updatedAt;
  }

  /**
   * Get entity properties for persistence
   */
  getProps(): {
    id: {{pascalName}}Id;
    name: string;
    description?: string;
    createdAt: Date;
    updatedAt: Date;
  } {
    return {
      id: this.id,
      name: this._name,
      description: this._description,
      createdAt: this._createdAt,
      updatedAt: this._updatedAt,
    };
  }
}

{{#if data.generateEvents}}
/**
 * Domain events for {{pascalName}}
 */

export class {{pascalName}}CreatedEvent implements DomainEvent {
  public readonly eventType = '{{pascalName}}Created';
  public readonly aggregateId: string;
  public readonly occurredOn: Date;

  constructor(
    public readonly {{camelName}}Id: {{pascalName}}Id,
    public readonly name: string
  ) {
    this.aggregateId = {{camelName}}Id.getValue();
    this.occurredOn = new Date();
  }
}

export class {{pascalName}}NameUpdatedEvent implements DomainEvent {
  public readonly eventType = '{{pascalName}}NameUpdated';
  public readonly aggregateId: string;
  public readonly occurredOn: Date;

  constructor(
    public readonly {{camelName}}Id: {{pascalName}}Id,
    public readonly newName: string
  ) {
    this.aggregateId = {{camelName}}Id.getValue();
    this.occurredOn = new Date();
  }
}
{{/if}}
