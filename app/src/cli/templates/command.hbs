import { Command } from '@/lib/shared/application/interfaces/command.interface';

/**
 * {{name}} command
 * Represents a command to perform {{name}} operation
 *
 * @author {{data.author}}
 * @license {{data.license}}
 */
export class {{pascalName}}Command implements Command {
  private constructor(
    public readonly id: string,
    public readonly name: string,
    public readonly description?: string
  ) {}

  /**
   * Create a new {{name}} command
   */
  static create(
    id: string,
    name: string,
    description?: string
  ): {{pascalName}}Command {
    if (!id || id.trim().length === 0) {
      throw new Error('ID is required');
    }

    if (!name || name.trim().length === 0) {
      throw new Error('Name is required');
    }

    return new {{pascalName}}Command(
      id.trim(),
      name.trim(),
      description?.trim()
    );
  }

  /**
   * Get command name for logging/debugging
   */
  getCommandName(): string {
    return '{{pascalName}}Command';
  }
}
